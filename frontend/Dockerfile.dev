# Development image — Node 22 with hot reload
FROM node:22-alpine

# Non-root user matching host (UID 1000)
RUN delgroup node 2>/dev/null; deluser node 2>/dev/null; \
    addgroup -g 1000 pixu && \
    adduser -u 1000 -G pixu -s /bin/sh -D pixu && \
    mkdir -p /workspace /home/pixu/.npm && \
    chown -R pixu:pixu /workspace /home/pixu

USER pixu
WORKDIR /workspace
ENV NODE_ENV=development

# Default: install deps then run dev server
CMD ["sh", "-c", "npm install --no-audit --no-fund --legacy-peer-deps && npm run dev"]