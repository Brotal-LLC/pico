# Development image — Node 22 with hot reload
FROM node:22-alpine

# Non-root user — handle existing UID/GID 1000 gracefully
RUN set -eux; \
    if ! getent group 1000 >/dev/null; then addgroup -g 1000 pixu; fi; \
    if ! id -u 1000 >/dev/null 2>&1; then \
      adduser -u 1000 -G pixu -s /bin/sh -D pixu 2>/dev/null || true; \
    fi; \
    mkdir -p /workspace /home/pixu/.npm && \
    chown -R 1000:1000 /workspace /home/pixu

USER pixu
WORKDIR /workspace
ENV NODE_ENV=development

# Default: install deps then run dev server
CMD ["sh", "-c", "npm install --no-audit --no-fund --legacy-peer-deps && npm run dev"]