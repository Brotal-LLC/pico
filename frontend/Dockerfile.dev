# Development image — Node 22 with hot reload
FROM node:22-alpine

# node:22-alpine already has UID 1000 (user: node, group: node)
# Use it directly instead of creating a new user
RUN mkdir -p /workspace /home/node/.npm && \
    chown -R node:node /workspace /home/node

USER node
WORKDIR /workspace
ENV NODE_ENV=development

# Default: install deps then run dev server
CMD ["sh", "-c", "npm install --no-audit --no-fund --legacy-peer-deps && npm run dev"]