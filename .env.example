# ─────────────────────────────────────────────
# PICO Environment Configuration
# Copy to .env and adjust as needed.
#
# Two compose files are shipped:
#   compose.yaml        – local development (reviewers, dev machines)
#   compose.prod.yaml   – production overlay (Caddy labels, pinned names)
#
# For local development, no extra config is required — `docker compose`
# will load compose.yaml by itself and pick up everything below.
#
# For production, set:
#   COMPOSE_FILE=compose.yaml:compose.prod.yaml
# so docker compose loads both files. See compose.prod.yaml for what
# that overlay adds.
# ─────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=pico
POSTGRES_PASSWORD=changeme
POSTGRES_DB=pico

# API
API_PORT=8080
PROVISIONING_MODE=mock          # mock | docker | openstack

# Frontend
FRONTEND_PORT=3000
# Browser-facing API URL (must be reachable from the user's browser)
NEXT_PUBLIC_API_URL=http://localhost:8080

# CORS (comma-separated list of allowed origins)
# Include every domain users will access the frontend from.
# e.g. Cors__AllowedOrigins=https://app.example.com, https://app.alt.example
Cors__AllowedOrigins=http://localhost:3000

# OpenStack (only used when PROVISIONING_MODE=openstack)
OpenStack__AuthUrl=http://192.168.122.43:5000/v3
OpenStack__Username=admin
OpenStack__Password=changeme
OpenStack__ProjectName=admin
OpenStack__Region=RegionOne

# Docker socket mount (only used when PROVISIONING_MODE=docker)
# Set to /var/run/docker.sock:/var/run/docker.sock to enable
DOCKER_SOCKET_MOUNT=/dev/null:/dev/null:ro

# Cookie domain. Empty (default) scopes cookies to the exact API host —
# correct for both local dev (cookies bound to localhost:8080) and
# production (cookies bound to whatever host serves the API). If the
# API is served from multiple subdomains of the same registrable domain
# that need to share cookies, set this to ".<your domain>".

# Data-protection keys path. ASP.NET Core uses these to encrypt/decrypt
# antiforgery cookies and other protected payloads. Persisting them to
# a known path (mounted as a Docker volume in compose.yaml / .prod.yaml)
# keeps the antiforgery cookie valid across API container restarts.
# Without this, every API bounce wipes the in-container key ring and
# login fails with 403 "antiforgery token could not be decrypted".
# Matches the Platform sibling repo pattern (st-idp / st-cerebrum /
# st-notifications).
# DataProtection__KeysPath=/var/aspnet-dpkeys

# ─── Deployment-only — produced stacks (compose.prod.yaml) ─────────────
# These are only consulted when compose.prod.yaml is in COMPOSE_FILE.

# COMPOSE_FILE=compose.yaml:compose.prod.yaml

# Public hostnames the Caddy reverse proxy will route to the API and
# frontend containers. These get baked into the Caddy labels and the
# browser-facing CORS allow-origin list — they MUST be the hostnames
# users actually visit, not the internal container names.
# API_HOST=api.example.com
# FRONTEND_HOST=app.example.com

# Optional: Cloudflare tunnel aliases or additional hostnames for the
# same containers. Comma-separated with the primary in the caddy label.
# API_HOST_ALT=api.alt.example
# FRONTEND_HOST_ALT=app.alt.example