# pico.aamar.cloud env example — copy to .env and edit for your setup.

# ─── Postgres ──────────────────────────────────────────────────────────────
POSTGRES_USER=pico
POSTGRES_PASSWORD=changeme
POSTGRES_DB=pico

# ─── Backend (.NET API) ───────────────────────────────────────────────────
# Used inside the docker network. Host-gateway is for the devcontainer.
ConnectionStrings__Default=Host=postgres;Port=5432;Database=pico;Username=pico;Password=changeme

# Provisioning backend: mock | docker | openstack
PROVISIONING_MODE=mock

# Auto-run EF migrations + seed on startup
Database__AutoMigrate=true
DemoData__Enabled=true

# OpenStack backend (only used when PROVISIONING_MODE=openstack)
OpenStack__AuthUrl=http://192.168.122.43:5000/v3
OpenStack__Username=admin
OpenStack__Password=changeme
OpenStack__ProjectName=admin
OpenStack__Region=RegionOne

# CORS — comma-separated origins
Cors__AllowedOrigins=https://pico.aamar.cloud,https://pico.ski.bd,http://localhost:3000

# ─── Frontend (Next.js) ────────────────────────────────────────────────────
# Public URL the browser uses to reach the API
NEXT_PUBLIC_API_URL=https://pico-api.aamar.cloud
# Internal URL used by server components inside the docker network
API_URL=http://api:8080

# ─── Cloudflare DNS (for Caddy TLS via DNS challenge) ──────────────────────
# Only needed for local live testing through https://pico.aamar.cloud
# Get from https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=changeme